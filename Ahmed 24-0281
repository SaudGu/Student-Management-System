#include <iostream>
#include <string>
#include <stdexcept>
using namespace std;


class Lesson {                    // This class shows one lesson and one week
private:
    int week;
    string title;

public:
    Lesson() {
        week= 1;
        title= "Introduction";
    }

    Lesson(int w, string t) {
        week= w;
        title= t;
    }
    void showLesson() const {
        cout << "Week " << week << ": " << title << endl;
    }
};


class User {            // this is the base class for the common user information
protected:
    string id;
    string name;

public:
    User() {
        id = "0";
        name = "Unknown";
    }

    User(string i, string n) {
        id= i;
        name =n;
    }

    virtual void showRole() const {
            cout << "General User" << endl;
    }

    string getId() const {
        return id;
    }

    string getName() const {
        return name;
    }
};
