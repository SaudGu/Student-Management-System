#include <iostream>
#include <string>
#include <stdexcept>
using namespace std;


class Lesson {                    // This class shows one lesson and one week
private:
    int week;
    string title;

public:
    Lesson() {
        week= 1;
        title= "Introduction";
    }

    Lesson(int w, string t) {
        week= w;
        title= t;
    }
    void showLesson() const {
        cout << "Week " << week << ": " << title << endl;
    }
};

class User {            // this is the base class for the common user information
protected:
    string id;
    string name;

public:
    User() {
        id = "0";
        name = "Unknown";
    }

    User(string i, string n) {
        id= i;
        name =n;
    }

    virtual void showRole() const {
            cout << "General User" << endl;
    }

    string getId() const {
        return id;
    }

    string getName() const {
        return name;
    }
};
class Student : public User {       // This is a derived class from User and it's called Student.
private:
    double grade;

public:
    Student() : User() {
        grade = 0;
    }

    Student(string i, string n) : User(i, n) {
        grade = 0;
    }

    void setGrade(double g) {
        if (g >= 0 && g <= 100) {
            grade = g;
        }
        else {
            cout << "Invalid grade" << endl;
        }
    }

    double getGrade() const {
        return grade;
    }

    void showRole() const override {
        cout << "Student" << endl;
    }

    void showStudent() const {
        cout << "Student ID: " << id << endl;
        cout << "Student Name: " << name << endl;
        cout << "Grade: " << grade << endl;
    }

};
class Instructor : public User {        //This is a derived class from User and it's called Instructor.
public:
    Instructor() : User() {
    }

    Instructor(string i, string n) : User(i, n) {
    }

    void showRole() const override {
        cout << "Instructor" << endl;
    }

    void showInstructor() const {
        cout << "Instructor ID: " << id << endl;
        cout << "Instructor Name: " << name << endl;
    }

};

class Course {
private:
    string code;
    string name;
    Instructor* instructor;  // Pointer used to assign instructor
    Lesson lesson;           // Composition: course has a lesson

public:
    Course() {
        code = "None";
        name = "None";
        instructor = nullptr;
    }

    Course(string c, string n, Lesson l) {
        code= c;
        name = n;
        lesson =l;
        instructor= nullptr;
    }

    string getCode() const {
        return code;
    }

    string getName() const {
        return name;
    }

    void assignInstructor(Instructor* i) {
        instructor =i;
    }

    void showCourse() const {
        cout << "Course Code : " << code << endl;
        cout << "Course Name:" << name << endl;

        if (instructor != nullptr) {
            cout << "Instructor: " << instructor->getName() << endl;
        } else {
            cout <<"Instructor: Not assigned yet" << endl;
        }

        lesson.showLesson();
    }
};
